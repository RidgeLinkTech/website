---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="RidgeLink Technologies | Secure Infrastructure & Cloud Services">
  <section class="hero">
    <div class="container">
      <div class="eyebrow">Fictional enterprise environment</div>
      <h1>Secure infrastructure, cloud, and cybersecurity services.</h1>
      <p class="lead">
        RidgeLink Technologies is a fictional IT services company built for realistic portfolio projects,
        ServiceNow demos, PowerShell automation examples, cybersecurity scenarios, and homelab documentation.
      </p>
      <div class="button-row">
        <a class="button" href="/services">Explore services</a>
        <a class="button secondary" href="/team">Meet the team</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-3">
      <article class="card">
        <h3>Infrastructure Engineering</h3>
        <p>Hybrid infrastructure, Windows Server, Linux, virtualization, storage, automation, and operational reliability.</p>
      </article>
      <article class="card">
        <h3>Cybersecurity</h3>
        <p>Security operations, vulnerability management, identity hardening, incident response, and secure architecture.</p>
      </article>
      <article class="card">
        <h3>Managed IT Support</h3>
        <p>Help desk, endpoint support, onboarding, device management, documentation, and service management workflows.</p>
      </article>
    </div>
  </section>
</BaseLayout>
