---
import '../styles.css';

const {
  title = 'RidgeLink Technologies',
  description = 'Secure infrastructure, cloud, cybersecurity, and managed IT services.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container nav">
        <a class="logo" href="/">RidgeLink Tech</a>
        <div class="nav-right">
          <nav class="nav-links" aria-label="Primary navigation">
            <a href="/about">About</a>
            <a href="/services">Services</a>
            <a href="/team">Team</a>
            <a href="/case-studies">Case Studies</a>
            <a href="/blog">Blog</a>
            <a href="/contact">Contact</a>
          </nav>
          <a
            class="linkedin-link"
            href="https://www.linkedin.com/in/skylerhart/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Visit Skyler Hart on LinkedIn"
            title="Skyler Hart on LinkedIn"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M4.98 3.5C4.98 4.88 3.87 6 2.49 6S0 4.88 0 3.5 1.11 1 2.49 1s2.49 1.12 2.49 2.5zM.5 8h4V24h-4V8zm7 0h3.83v2.18h.06c.53-1.01 1.84-2.08 3.79-2.08 4.05 0 4.8 2.66 4.8 6.11V24h-4v-6.86c0-1.64-.03-3.75-2.29-3.75-2.29 0-2.64 1.79-2.64 3.63V24h-4V8z"/>
            </svg>
            <span>LinkedIn</span>
          </a>
        </div>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="container">
        <strong>RidgeLink Technologies</strong><br />
        Fictional company site for portfolio, demos, documentation, and lab scenarios.
        <div class="footer-social">
          <a
            class="linkedin-link"
            href="https://www.linkedin.com/in/skylerhart/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Visit Skyler Hart on LinkedIn"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M4.98 3.5C4.98 4.88 3.87 6 2.49 6S0 4.88 0 3.5 1.11 1 2.49 1s2.49 1.12 2.49 2.5zM.5 8h4V24h-4V8zm7 0h3.83v2.18h.06c.53-1.01 1.84-2.08 3.79-2.08 4.05 0 4.8 2.66 4.8 6.11V24h-4v-6.86c0-1.64-.03-3.75-2.29-3.75-2.29 0-2.64 1.79-2.64 3.63V24h-4V8z"/>
            </svg>
            <span>Connect on LinkedIn</span>
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
