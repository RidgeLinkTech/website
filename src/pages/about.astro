---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | RidgeLink Technologies">
  <section class="section">
    <div class="container">
      <div class="eyebrow">About RidgeLink Tech</div>
      <h1>What is RidgeLink Technologies?</h1>
      <p class="lead">
        It's Skyler Hart's enterprise engineering portfolio. A fictional company keeps documentation,
        architecture, automation, and demos in one consistent environment. Everything technical reflects real
        practices; the company and employees provide context for the examples.
      </p>
      <div class="grid grid-3">
        <article class="card">
          <h3>Mission</h3>
          <p>Demonstrate secure, reliable, and scalable engineering practices in a realistic enterprise-style setting.</p>
        </article>
        <article class="card">
          <h3>Values</h3>
          <p>Security by design, automation first, documentation matters, and practical engineering over unnecessary complexity.</p>
        </article>
        <article class="card">
          <h3>Use</h3>
          <p>Use this site as the front door for ServiceNow, Microsoft 365, Entra ID, AD, SIEM, and cloud portfolio demos.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
