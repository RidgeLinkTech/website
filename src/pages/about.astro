---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | RidgeLink Technologies">
  <section class="section">
    <div class="container">
      <div class="eyebrow">About RidgeLink Tech</div>
      <h1>Built as a realistic fictional company for technical demos.</h1>
      <p class="lead">
        RidgeLink Technologies provides a consistent fictional company, employee directory, service catalog,
        and business context for technical labs, documentation, demos, and portfolio content.
      </p>
      <div class="grid grid-3">
        <article class="card">
          <h3>Mission</h3>
          <p>Deliver secure, reliable, and scalable technology solutions that enable organizations to focus on their mission.</p>
        </article>
        <article class="card">
          <h3>Values</h3>
          <p>Security by design, automation first, documentation matters, and practical engineering over unnecessary complexity.</p>
        </article>
        <article class="card">
          <h3>Use</h3>
          <p>Use this site as the front door for fictional ServiceNow, Microsoft 365, Entra ID, AD, SIEM, and cloud demos.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
