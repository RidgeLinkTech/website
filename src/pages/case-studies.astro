---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const studies = await getCollection('case-studies');
---

<BaseLayout title="Case Studies | RidgeLink Technologies">
  <section class="section">
    <div class="container">
      <div class="eyebrow">Case Studies</div>
      <h1>Fictional project examples</h1>
      <div class="grid grid-3">
        {studies.map((study) => (
          <article class="card">
            <h3>{study.data.title}</h3>
            <strong>{study.data.client}</strong>
            <p>{study.data.summary}</p>
            <div class="badges">
              {study.data.services.map((service) => <span class="badge">{service}</span>)}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
