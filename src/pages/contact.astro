---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | RidgeLink Technologies">
  <section class="section">
    <div class="container">
      <div class="eyebrow">Contact</div>
      <h1>Contact RidgeLink Technologies</h1>
      <p class="lead">
        Use LinkedIn to connect and follow updates from this enterprise
        engineering portfolio.
      </p>
      <article class="card">
        <p><strong>Website:</strong> https://ridgelink.us</p>
        <p>
          <strong>LinkedIn:</strong>
          <a
            href="https://www.linkedin.com/in/skylerhart/"
            target="_blank"
            rel="noopener noreferrer"
          >
            linkedin.com/in/skylerhart
          </a>
        </p>
        <p><strong>Headquarters:</strong> Frederick, Maryland</p>
      </article>
    </div>
  </section>
</BaseLayout>
