---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="RidgeLink Technologies | Secure Infrastructure & Cloud Services">
  <section class="hero">
    <div class="container">
      <div class="eyebrow">Enterprise Engineering Portfolio</div>
      <h1>RidgeLink Technologies is Skyler Hart's enterprise engineering portfolio.</h1>
      <p class="lead">
        This fictional company exists as a portfolio demonstrating enterprise engineering practices. I use a
        fictional company so all documentation, architecture, automation, and demos live in one consistent
        environment. Everything technical reflects real practices; the company and employees provide context
        for the examples.
      </p>
      <div class="button-row">
        <a class="button" href="/services">Explore services</a>
        <a class="button secondary" href="/team">Meet the team</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid grid-3">
      <article class="card">
        <h3>Infrastructure Engineering</h3>
        <p>Hybrid infrastructure, Windows Server, Linux, virtualization, storage, automation, and operational reliability.</p>
      </article>
      <article class="card">
        <h3>Cybersecurity</h3>
        <p>Security operations, vulnerability management, identity hardening, incident response, and secure architecture.</p>
      </article>
      <article class="card">
        <h3>Managed IT Support</h3>
        <p>Help desk, endpoint support, onboarding, device management, documentation, and service management workflows.</p>
      </article>
    </div>
  </section>
</BaseLayout>
