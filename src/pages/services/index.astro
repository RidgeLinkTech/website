---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  ['Infrastructure Engineering', ['Windows Server and Linux administration', 'Virtualization and storage', 'Backup and disaster recovery', 'PowerShell automation']],
  ['Cloud Services', ['Microsoft Azure', 'Microsoft 365', 'Entra ID', 'Hybrid cloud architecture']],
  ['Cybersecurity', ['Security operations', 'Vulnerability management', 'Identity hardening', 'Incident response']],
  ['Networking', ['Routing and switching', 'Wireless', 'Firewalls and VPN', 'Network monitoring']],
  ['Managed IT Support', ['Help desk', 'Endpoint support', 'Onboarding and offboarding', 'Knowledge management']]
];
---

<BaseLayout title="Services | RidgeLink Technologies">
  <section class="section">
    <div class="container">
      <div class="eyebrow">Services</div>
      <h1>Practical technology services for a fictional enterprise.</h1>
      <div class="grid grid-3">
        {services.map(([title, items]) => (
          <article class="card">
            <h3>{title}</h3>
            <ul class="service-list">
              {items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
