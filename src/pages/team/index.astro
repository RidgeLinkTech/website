---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PersonaCard from '../../components/PersonaCard.astro';
import { getCollection } from 'astro:content';

const personas = await getCollection('personas');
const teamOrder = ['Leadership', 'Network & Infrastructure', 'Systems', 'Cybersecurity', 'Support'];
const grouped = teamOrder.map((team) => ({
  team,
  people: personas.filter((p) => p.data.team === team)
}));
---

<BaseLayout title="Team | RidgeLink Technologies">
  <section class="section">
    <div class="container">
      <div class="eyebrow">Team</div>
      <h1>RidgeLink Technologies Persona Directory</h1>
      <p class="lead">A fictional employee directory for demos, documentation, screenshots, training, and portfolio projects.</p>

      {grouped.map((group) => (
        <section class="section">
          <h2>{group.team}</h2>
          <div class="grid grid-3">
            {group.people.map((person) => <PersonaCard person={person} />)}
          </div>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
